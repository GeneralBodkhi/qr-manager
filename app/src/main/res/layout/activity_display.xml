<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:padding="24dp"
    tools:context=".DisplayActivity">

    <TextView
        android:id="@+id/tvQrName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Название кода"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp" />

    <ImageView
        android:id="@+id/ivQrCode"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_centerInParent="true"
        android:contentDescription="Ваш QR-код" />

    <TextView
        android:id="@+id/tvQrContentText"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:text="Тут будет текст"
        android:textSize="18sp"
        android:background="#F5F5F5"
        android:padding="16dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground" />

    <Button
        android:id="@+id/btnToggleMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Расшифровать"
        android:textSize="18sp"
        android:padding="12dp"
        android:layout_above="@id/btnSave"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сохранить в галерею"
        android:textSize="18sp"
        android:padding="12dp"
        android:layout_above="@id/btnClose"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Назад к списку"
        android:textSize="18sp"
        android:padding="12dp"
        android:layout_alignParentBottom="true" />

</RelativeLayout>